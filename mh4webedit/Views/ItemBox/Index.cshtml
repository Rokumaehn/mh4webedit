@using mh4edit
@model mh4webedit.Models.ItemBoxViewModel

<h2>Item Box</h2>

@if (TempData["ItemBoxMessage"] != null)
{
    <div class="alert alert-success">@TempData["ItemBoxMessage"]</div>
}

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Page" />

    <table class="table table-striped">
        <thead>
            <tr>
                <th>#</th>
                <th>Item</th>
                <th>Quantity</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Items.Count; i++)
            {
                <tr>
                    <td>@(((Model.Page - 1) * Model.ItemsPerPage) + i + 1)</td>
                    <td>
                        <select data-index="@i" data-current="@Model.Items[i].ItemId" class="form-select item-select" aria-label="Item select @i"></select>
                    </td>
                    <td>
                        <input asp-for="Items[i].Quantity" class="form-control" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between">
        <div>
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page - 1)" class="btn btn-secondary">Previous</a>
            }
        </div>
        <div>
            <button type="submit" class="btn btn-success">Save</button>
            @if ((Model.Page * Model.ItemsPerPage) < Model.TotalItems)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page + 1)" class="btn btn-primary ms-2">Next</a>
            }
        </div>
    </div>
</form>

<script>
    (function(){
        const CACHE_KEY = 'mh4_item_names_v1';

        function buildOptions(names){
            return names.map(function(n,i){
                return '<option value="'+i+'">'+(n === null ? '' : n.replace(/</g,'&lt;').replace(/>/g,'&gt;'))+'</option>';
            }).join('');
        }

        function populate(optsHtml){
            document.querySelectorAll('.item-select').forEach(function(sel){
                sel.innerHTML = optsHtml;
                const idx = sel.getAttribute('data-index');
                sel.name = 'Items['+idx+'].ItemId';
                const cur = sel.getAttribute('data-current');
                if(cur !== null && cur !== ''){
                    const opt = sel.querySelector('option[value="'+cur+'"]');
                    if(opt) opt.selected = true;
                }
            });
        }

        try{
            var cachedRaw = localStorage.getItem(CACHE_KEY);
            var cached = null;
            if(cachedRaw){
                cached = JSON.parse(cachedRaw);
                if(cached && cached.names){
                    // optimistically populate from cache while we validate with server
                    populate(buildOptions(cached.names));
                }
            }
        }catch(e){
            console.warn('Item names cache parse failed', e);
            cached = null;
        }

        var headers = { };
        if(cached && cached.etag){ headers['If-None-Match'] = cached.etag; }

        fetch('@Url.Action("ItemNames","ItemBox")', { headers: headers })
            .then(function(r){
                if(r.status === 304){
                    // not modified - keep cached names
                    return null;
                }
                if(!r.ok) throw new Error('Network response not ok');
                var newEtag = r.headers.get('ETag');
                return r.json().then(function(names){ return { names: names, etag: newEtag }; });
            })
            .then(function(result){
                if(result === null) return; // cached still valid
                try{ localStorage.setItem(CACHE_KEY, JSON.stringify({ etag: result.etag, names: result.names })); }catch(e){}
                populate(buildOptions(result.names));
            })
            .catch(function(err){ console.error('Failed to load item names', err); });
    })();
</script>
